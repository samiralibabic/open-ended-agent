# OpenAI-compatible endpoint (any works: Ollama, LiteLLM, llama.cpp, TurboQuant)
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local
MODEL=qwen3.5:8b

# LiteLLM / local stack example
# OPENAI_BASE_URL=http://localhost:4000/v1
# MODEL=qwen3.5-35b-a3b

# llama.cpp / TurboQuant example
# OPENAI_BASE_URL=http://127.0.0.1:8080/v1
# MODEL=qwen3.5-27b-turboquant

# Loop behavior
AGENT_HOME=./agent-home
AGENT_MAX_CYCLES=0              # 0 = no stop condition; Ctrl+C to stop
AGENT_CONTEXT_CHAR_BUDGET=90000 # raise for large-context models (e.g. TurboQuant 262k): 120000
AGENT_RECENT_LOG_CYCLES=6
AGENT_COMPACT_EVERY=20
AGENT_TICK_DELAY_MS=0

# Model behavior
AGENT_TEMPERATURE=0.4
AGENT_MAX_TOKENS=768
AGENT_COMPACTION_MAX_TOKENS=1536
AGENT_LLM_STREAM=1
AGENT_LLM_TIMEOUT_MS=0
AGENT_MAX_RESPONSE_CHARS=30000
AGENT_JSON_MODE=1

# Tools
AGENT_WEB=1       # enabled by default; set 0 to disable web search and fetch
AGENT_SHELL=0     # disabled by default; set 1 to enable restricted shell commands
AGENT_SHELL_TIMEOUT_MS=15000
AGENT_FETCH_TIMEOUT_MS=20000
AGENT_FETCH_TEXT_CHARS=12000    # preview returned to model; full content cached in artifacts/web-cache/
AGENT_CONTEXT_RESULT_CHARS=6000 # previous observation truncation
AGENT_OBSERVE_MAX_ENTRIES=80    # file tree entries per observe action